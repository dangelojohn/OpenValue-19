<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="mrp_workcenter_view_mpc" model="ir.ui.view">
        <field name="name">mrp.workcenter.form.costing</field>
        <field name="model">mrp.workcenter</field>
        <field name="inherit_id" ref="mrp.mrp_workcenter_view"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button class="oe_stat_button" name="attachment_tree_view" type="object" icon="fa-files-o">
                    <field string="Documents" name="doc_count" widget="statinfo"/>
                </button>
            </xpath>
            <field name="name" position="after">
                <field name="wc_type" required="1"/>
            </field>
            <xpath expr="//notebook" position="inside">
                <page string="Costing Data" name="costing_data">
                    <group col="3">
                        <group string="Direct Costs Rates">
                            <field name="currency_id" invisible="1"/>
                            <field name="costs_hour" widget="monetary" options="{'currency_field': 'currency_id'}" required="1"/>
                            <field name="costs_hour_fixed" widget="monetary" options="{'currency_field': 'currency_id'}" required="1"/>
                        </group>
                        <group string="Analytic Account">
                            <field name="analytic_account_id" groups="analytic.group_analytic_accounting" required="1"/>
                        </group>
                        <group string="Overhead Costs">
                            <label for="costs_overhead_variable_percentage" string="Variable Direct percentage"/>
                            <div class="o_row">
                                <field name="costs_overhead_variable_percentage" required="1"/>
                                %
                            </div>
                            <label for="costs_overhead_fixed_percentage" string="Fixed Direct percentage"/>
                            <div class="o_row">
                                <field name="costs_overhead_fixed_percentage" required="1"/>
                                %
                            </div>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <record id="view_product_costing_workcenter_list" model="ir.ui.view">
        <field name="name">mrp.workcenter.product.costing.list</field>
        <field name="model">mrp.workcenter</field>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <list string="Work Center" multi_edit="1">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code" optional="show"/>
                <field name="wc_type" optional="show"/>
                <field name="tag_ids" widget="many2many_tags" options="{'no_create': True, 'color_field': 'color'}" optional="show"/>
                <field name="costs_hour" optional="show" string="Variable Cost Rate"/>
                <field name="costs_hour_fixed" optional="show" string="Fixed Cost Rate"/>
                <field name="time_efficiency" optional="show"/>
                <field name="oee_target" optional="show"/>
                <field name="time_start" optional="show"/>
                <field name="time_stop" optional="show"/>
                <field name="company_id" groups="base.group_multi_company" optional="hide"/>
                <field name="active" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_product_costing_workcenter_filter" model="ir.ui.view">
        <field name="name">mrp.workcenter.product.costing.filter</field>
        <field name="model">mrp.workcenter</field>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <search string="Search for mrp workcenter">
                <field name="name" string="Work Center" filter_domain="['|', ('name', 'ilike', self), ('code', 'ilike', self)]"/>
                <filter name="archived" string="Archived" domain="[('active', '=', False)]"/>
                <group>
                    <filter string="Work Center Type" name="wc_type" domain="[]" context="{'group_by': 'wc_type'}"/>
                    <filter string="Company" name="company" domain="[]" context="{'group_by': 'company_id'}" groups="base.group_multi_company"/>
                </group>
                <searchpanel>
                    <field name="tag_ids" select="multi" icon="fa-tag" enable_counters="1"/>
                </searchpanel>
            </search>
        </field>
    </record>

    <record id="product_costing_workcenter_action" model="ir.actions.act_window">
        <field name="name">Work Centers</field>
        <field name="res_model">mrp.workcenter</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="search_view_id" ref="view_product_costing_workcenter_filter"/>
        <field name="view_id" ref="view_product_costing_workcenter_list"/>
    </record>

    <menuitem id="mrp.menu_mrp_bom"
              name="Master Data"
              parent="mrp.menu_mrp_root"
              sequence="20"/>

    <menuitem id="menu_workcenter"
              action="product_costing_workcenter_action"
              groups="mrp.group_mrp_routings"
              parent="mrp.menu_mrp_bom"
              sequence="90"/>
</odoo>
