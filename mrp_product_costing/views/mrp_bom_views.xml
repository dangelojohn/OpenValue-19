<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="mrp_bom_view" model="ir.ui.view">
        <field name="name">mrp.bom.form.costing</field>
        <field name="model">mrp.bom</field>
        <field name="inherit_id" ref="mrp.mrp_bom_form_view"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page string="Costing Data" name="costing_data" invisible="type != 'normal'">
                    <group string="Variances Analysis">
                        <group>
                            <field name="costs_planned_variances_analytic_account_id" groups="analytic.group_analytic_accounting" required="type == 'normal'"/>
                            <field name="costs_material_variances_analytic_account_id" groups="analytic.group_analytic_accounting" required="type == 'normal'"/>
                            <field name="costs_direct_variances_analytic_account_id" groups="analytic.group_analytic_accounting" required="type == 'normal'"/>
                        </group>
                        <group/>
                    </group>
                    <group string="Overhead Costs">
                        <group>
                            <label for="costs_overhead_product_percentage" string="Finished Product percentage"/>
                            <div class="o_row">
                                <field name="costs_overhead_product_percentage" required="type == 'normal'"/>
                                %
                            </div>
                            <label for="costs_overhead_components_percentage" string="Components percentage"/>
                            <div class="o_row">
                                <field name="costs_overhead_components_percentage" required="type == 'normal'"/>
                                %
                            </div>
                        </group>
                        <group>
                            <field name="overhead_analytic_account_id" groups="analytic.group_analytic_accounting" required="type == 'normal'"/>
                        </group>
                    </group>
                </page>
            </notebook>
        </field>
    </record>
</odoo>
