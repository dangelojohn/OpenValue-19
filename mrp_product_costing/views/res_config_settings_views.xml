<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.mrp.product.costing</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="mrp.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//app[@name='mrp']" position="inside">
                <block title="Product Costing" name="mrp_product_costing">
                    <setting string="Direct cost accounts"
                             help="Accounts used for direct (labour / machine) cost postings.">
                        <div class="content-group">
                            <div class="row mt8">
                                <label for="labour_cost_account_id" class="col-lg-6 o_light_label"/>
                                <field name="labour_cost_account_id"/>
                            </div>
                            <div class="row mt8">
                                <label for="machine_run_cost_account_id" class="col-lg-6 o_light_label"/>
                                <field name="machine_run_cost_account_id"/>
                            </div>
                            <div class="row mt8">
                                <label for="labour_fixed_cost_account_id" class="col-lg-6 o_light_label"/>
                                <field name="labour_fixed_cost_account_id"/>
                            </div>
                            <div class="row mt8">
                                <label for="machine_run_fixed_cost_account_id" class="col-lg-6 o_light_label"/>
                                <field name="machine_run_fixed_cost_account_id"/>
                            </div>
                        </div>
                    </setting>
                    <setting string="Variance accounts"
                             help="Accounts used for variance cost postings at closure.">
                        <div class="content-group">
                            <div class="row mt8">
                                <label for="planned_variances_account_id" class="col-lg-6 o_light_label"/>
                                <field name="planned_variances_account_id"/>
                            </div>
                            <div class="row mt8">
                                <label for="material_variances_account_id" class="col-lg-6 o_light_label"/>
                                <field name="material_variances_account_id"/>
                            </div>
                            <div class="row mt8">
                                <label for="other_variances_account_id" class="col-lg-6 o_light_label"/>
                                <field name="other_variances_account_id"/>
                            </div>
                        </div>
                    </setting>
                    <setting string="Manufacturing journal"
                             help="Journal collecting manufacturing accounting postings.">
                        <field name="manufacturing_journal_id"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
