<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_mrp_workcenter_form_maintenance" model="ir.ui.view">
        <field name="name">mrp.workcenter.form.maintenance</field>
        <field name="model">mrp.workcenter</field>
        <field name="inherit_id" ref="mrp.mrp_workcenter_view"/>
        <field name="arch" type="xml">
            <div name="button_box" position="inside">
                <button name="action_view_maintenance_requests" type="object"
                        class="oe_stat_button" icon="fa-wrench"
                        invisible="maintenance_request_count == 0">
                    <field name="maintenance_request_count" widget="statinfo"
                           string="Maintenance"/>
                </button>
            </div>
        </field>
    </record>

</odoo>
