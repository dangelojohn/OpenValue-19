<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_mrp_routing_workcenter_form_external" model="ir.ui.view">
        <field name="name">mrp.routing.workcenter.form.external</field>
        <field name="model">mrp.routing.workcenter</field>
        <field name="inherit_id" ref="mrp.mrp_routing_workcenter_form_view"/>
        <field name="arch" type="xml">
            <field name="workcenter_id" position="after">
                <field name="is_external"/>
                <field name="external_partner_id"
                       invisible="not is_external"
                       required="is_external"
                       options="{'no_create': True}"/>
                <field name="external_service_product_id"
                       invisible="not is_external"
                       required="is_external"
                       options="{'no_create': True}"/>
                <field name="external_price" invisible="not is_external"/>
            </field>
        </field>
    </record>

</odoo>
