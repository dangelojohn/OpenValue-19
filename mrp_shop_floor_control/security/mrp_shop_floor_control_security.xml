<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="group_mrp_confirmation" model="res.groups">
            <field name="name">Manage Classical MRP Workorder Confirmation</field>
        </record>
    </data>

    <data noupdate="1">
        <record id="mrp_floating_times_multicompany_rule" model="ir.rule">
            <field name="name">mrp.floating.times multi-company</field>
            <field name="model_id" ref="model_mrp_floating_times"/>
            <field name="global" eval="True"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>

        <record id="mrp_workcenter_load_multicompany_rule" model="ir.rule">
            <field name="name">mrp.workcenter.load multi-company</field>
            <field name="model_id" ref="model_mrp_workcenter_load"/>
            <field name="global" eval="True"/>
            <field name="domain_force">['|', ('workcenter_id.company_id', '=', False), ('workcenter_id.company_id', 'in', company_ids)]</field>
        </record>
    </data>
</odoo>
