<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Editable work order list (embedded in the MO form and standalone) -->
    <record id="mrp_production_workorder_tree_editable_view_sfc" model="ir.ui.view">
        <field name="name">mrp.production.work.order.list.editable.sfc</field>
        <field name="model">mrp.workorder</field>
        <field name="inherit_id" ref="mrp.mrp_production_workorder_tree_editable_view"/>
        <field name="arch" type="xml">
            <field name="workcenter_id" position="after">
                <field name="sfc_sequence" optional="show"/>
                <field name="milestone" optional="show"/>
                <field name="date_planned_start_wo" optional="show"/>
                <field name="date_planned_finished_wo" optional="show"/>
                <field name="date_actual_start_wo" optional="hide"/>
                <field name="date_actual_finished_wo" optional="hide"/>
                <field name="qty_output_wo" optional="show" readonly="state in ['done', 'cancel']"/>
            </field>
            <field name="duration" position="after">
                <field name="overall_duration" widget="float_time" optional="hide"/>
            </field>
        </field>
    </record>

    <!-- Work order form -->
    <record id="mrp_production_workorder_form_view_sfc" model="ir.ui.view">
        <field name="name">mrp.production.work.order.form.sfc</field>
        <field name="model">mrp.workorder</field>
        <field name="inherit_id" ref="mrp.mrp_production_workorder_form_view_inherit"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page string="Shop Floor Control" name="sfc">
                    <group>
                        <group string="SFC Scheduled Dates">
                            <field name="date_planned_start_wo" readonly="1"/>
                            <field name="date_planned_finished_wo" readonly="1"/>
                            <field name="date_actual_start_wo" readonly="1"/>
                            <field name="date_actual_finished_wo" readonly="1"/>
                        </group>
                        <group string="Capacity">
                            <field name="sfc_sequence"/>
                            <field name="milestone"/>
                            <field name="wo_capacity_requirements" widget="float_time"/>
                            <field name="overall_duration" widget="float_time" readonly="1"/>
                            <field name="qty_output_wo" readonly="state in ['done', 'cancel']"/>
                            <field name="prev_work_order_id" readonly="1"/>
                            <field name="qty_output_prev_wo" readonly="1"/>
                        </group>
                    </group>
                </page>
            </notebook>
        </field>
    </record>

    <!-- Extra search filter -->
    <record id="view_mrp_production_workorder_filter_sfc" model="ir.ui.view">
        <field name="name">mrp.production.work.order.search.sfc</field>
        <field name="model">mrp.workorder</field>
        <field name="inherit_id" ref="mrp.view_mrp_production_workorder_form_view_filter"/>
        <field name="arch" type="xml">
            <search position="inside">
                <filter string="SFC Late" name="sfc_late"
                        domain="[('date_planned_start_wo', '&lt;', context_today().strftime('%Y-%m-%d')), ('state', 'in', ('ready', 'pending', 'waiting'))]"/>
            </search>
        </field>
    </record>

    <!-- Mid point scheduling wizard -->
    <record id="set_date_wizard_form" model="ir.ui.view">
        <field name="name">set.date.wizard.form</field>
        <field name="model">set.date.wizard</field>
        <field name="arch" type="xml">
            <form string="Mid Point Scheduling">
                <group>
                    <field name="new_date_planned_start_wo"/>
                    <field name="workorder_id"/>
                </group>
                <footer>
                    <button class="btn-primary" name="set_date" type="object" string="Mid Point Scheduling"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_set_date_wizard" model="ir.actions.act_window">
        <field name="name">Mid Point Scheduling</field>
        <field name="res_model">set.date.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="mrp.model_mrp_workorder"/>
        <field name="binding_view_types">form,list</field>
    </record>

    <!-- Capacity leveling list -->
    <record id="mrp_workorder_capacity_leveling_list" model="ir.ui.view">
        <field name="name">mrp.workorder.capacity.leveling.list</field>
        <field name="model">mrp.workorder</field>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <list string="Work Orders" delete="0" create="0"
                  decoration-success="date_planned_start_wo &gt;= current_date and state == 'ready'"
                  decoration-muted="state in ('done', 'cancel')"
                  decoration-danger="date_planned_start_wo &lt; current_date and state == 'ready'">
                <field name="workcenter_id"/>
                <field name="wo_capacity_requirements" widget="float_time" sum="Total Capacity Requirements"/>
                <field name="name"/>
                <field name="production_id"/>
                <field name="product_id"/>
                <field name="qty_production" string="Qty"/>
                <field name="product_uom_id" string="UoM"/>
                <field name="state"/>
                <field name="date_planned_start_wo"/>
                <field name="date_planned_finished_wo"/>
                <button name="%(action_set_date_wizard)d" type="action" string="Mid Point Scheduling" class="btn-primary"/>
            </list>
        </field>
    </record>

    <record id="mrp_workorder_capacity_leveling_action" model="ir.actions.act_window">
        <field name="name">Work Order Capacity Leveling</field>
        <field name="res_model">mrp.workorder</field>
        <field name="domain">[('state', 'in', ('ready', 'pending', 'waiting'))]</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="mrp_workorder_capacity_leveling_list"/>
        <field name="search_view_id" ref="mrp.view_mrp_production_workorder_form_view_filter"/>
    </record>

    <menuitem id="menu_mrp_capacity_leveling"
              sequence="55"
              parent="mrp.menu_mrp_reporting"
              action="mrp_workorder_capacity_leveling_action"
              groups="mrp.group_mrp_user"/>
</odoo>
