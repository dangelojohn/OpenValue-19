<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="mrp_production_list_view_sfc" model="ir.ui.view">
        <field name="name">mrp.production.list.sfc</field>
        <field name="model">mrp.production</field>
        <field name="inherit_id" ref="mrp.mrp_production_tree_view"/>
        <field name="arch" type="xml">
            <field name="name" position="after">
                <field name="date_planned_start_pivot" optional="show"
                       decoration-danger="state not in ('done', 'cancel') and date_planned_start_pivot &lt; current_date"/>
                <field name="date_planned_finished_pivot" optional="hide"/>
                <field name="date_planned_start_wo" optional="hide"/>
                <field name="date_planned_finished_wo" optional="hide"/>
            </field>
        </field>
    </record>

    <record id="mrp_production_form_view_sfc" model="ir.ui.view">
        <field name="name">mrp.production.form.sfc</field>
        <field name="model">mrp.production</field>
        <field name="inherit_id" ref="mrp.mrp_production_form_view"/>
        <field name="arch" type="xml">
            <button name="button_plan" position="after">
                <button name="%(action_mrp_starting)d" type="action" string="WO Starting"
                        class="oe_highlight"
                        invisible="not is_scheduled or state in ('draft', 'to_close', 'done', 'cancel') or not workorder_ids"/>
                <button name="%(action_mrp_confirmation)d" type="action" string="WO Confirmation"
                        class="oe_highlight"
                        invisible="not is_scheduled or state in ('draft', 'to_close', 'done', 'cancel') or not workorder_ids"/>
                <button name="action_capacity_check" type="object" string="Capacity Load"
                        invisible="state in ('draft', 'done', 'cancel') or not is_scheduled"/>
            </button>
            <xpath expr="//notebook" position="inside">
                <page string="Shop Floor Control" name="sfc" invisible="not workorder_ids">
                    <field name="is_scheduled" invisible="1"/>
                    <field name="hours_uom" invisible="1"/>
                    <group>
                        <group string="Planning">
                            <field name="planning_mode" readonly="is_scheduled"/>
                            <field name="date_planned_start_pivot" readonly="is_scheduled"/>
                            <field name="date_planned_finished_pivot" readonly="is_scheduled or planning_mode == 'F'"/>
                            <field name="qty_confirmed"/>
                        </group>
                        <group string="Scheduled / Actual Dates">
                            <field name="date_planned_start_wo" readonly="1"/>
                            <field name="date_planned_finished_wo" readonly="1"/>
                            <field name="date_actual_start_wo" readonly="1"/>
                            <field name="date_actual_finished_wo" readonly="1"/>
                        </group>
                    </group>
                    <group col="3">
                        <group string="Standard Times">
                            <field name="std_setup_time" widget="float_time"/>
                            <field name="std_working_time" widget="float_time"/>
                            <field name="std_teardown_time" widget="float_time"/>
                            <field name="std_overall_time" widget="float_time"/>
                        </group>
                        <group string="Planned Times">
                            <field name="planned_duration_expected" widget="float_time"/>
                            <field name="unplanned_duration_expected" widget="float_time"/>
                        </group>
                        <group string="Actual Times">
                            <field name="act_setup_time" widget="float_time"/>
                            <field name="act_working_time" widget="float_time"/>
                            <field name="act_teardown_time" widget="float_time"/>
                            <field name="act_overall_time" widget="float_time"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
