<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="mrp_bom_form_view_sfc" model="ir.ui.view">
        <field name="name">mrp.bom.form.sfc</field>
        <field name="model">mrp.bom</field>
        <field name="inherit_id" ref="mrp.mrp_bom_form_view"/>
        <field name="arch" type="xml">
            <page name="operations" position="attributes">
                <attribute name="invisible">type != 'normal'</attribute>
            </page>
            <xpath expr="//field[@name='bom_line_ids']//field[@name='product_id']" position="after">
                <field name="child_bom_id" column_invisible="1"/>
                <button name="open_bom" icon="fa-flask" title="Open BoM" type="object"
                        invisible="not child_bom_id"/>
            </xpath>
        </field>
    </record>
</odoo>
