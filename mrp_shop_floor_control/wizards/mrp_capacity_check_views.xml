<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="mrp_capacity_check_view_form" model="ir.ui.view">
        <field name="name">mrp.capacity.check.form</field>
        <field name="model">mrp.capacity.check</field>
        <field name="arch" type="xml">
            <form string="Capacity Check">
                <field name="production_id" invisible="1"/>
                <field name="capacity_item_ids" nolabel="1">
                    <list edit="0" create="0">
                        <field name="week_nro"/>
                        <field name="workcenter_id"/>
                        <field name="wo_capacity_requirements" widget="float_time" string="WO Requirements (H)"/>
                        <field name="wc_available_capacity" widget="float_time" string="WC Weekly Available (H)"/>
                        <field name="all_wo_capacity_requirements" widget="float_time" string="All WO Requirements (H)"/>
                        <field name="wc_capacity_load" string="Loading %"/>
                        <field name="wc_remaining_capacity" widget="float_time" string="WC Remaining (H)"/>
                        <button name="open_pivot_info" type="object" string="Capacity Detail" class="btn-link"/>
                    </list>
                </field>
                <footer>
                    <button special="cancel" string="Close" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
