<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_maintenance_plan_list" model="ir.ui.view">
        <field name="name">maintenance.plan.list</field>
        <field name="model">maintenance.plan</field>
        <field name="arch" type="xml">
            <list string="Maintenance Plans">
                <field name="name"/>
                <field name="equipment_id"/>
                <field name="maintenance_type"/>
                <field name="interval_number"/>
                <field name="interval_type"/>
                <field name="next_date"/>
                <field name="maintenance_team_id" optional="show"/>
                <field name="request_count" string="Requests"/>
            </list>
        </field>
    </record>

    <record id="view_maintenance_plan_form" model="ir.ui.view">
        <field name="name">maintenance.plan.form</field>
        <field name="model">maintenance.plan</field>
        <field name="arch" type="xml">
            <form string="Maintenance Plan">
                <header>
                    <button name="action_generate_request" type="object"
                            string="Generate Request" class="oe_highlight"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_generate_request" type="object"
                                class="oe_stat_button" icon="fa-wrench">
                            <field name="request_count" widget="statinfo" string="Requests"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="e.g. Quarterly inspection"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="equipment_id" options="{'no_create': True}"/>
                            <field name="maintenance_type"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                        <group>
                            <label for="interval_number"/>
                            <div class="o_row">
                                <field name="interval_number"/>
                                <field name="interval_type"/>
                            </div>
                            <field name="next_date"/>
                            <field name="maintenance_team_id"/>
                            <field name="technician_user_id"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_maintenance_plan" model="ir.actions.act_window">
        <field name="name">Maintenance Plans</field>
        <field name="res_model">maintenance.plan</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_maintenance_plan"
              name="Maintenance Plans"
              parent="maintenance.menu_maintenance_title"
              action="action_maintenance_plan"
              sequence="25"
              groups="maintenance.group_equipment_manager"/>

</odoo>
