<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_mrp_mps_report_form" model="ir.ui.view">
        <field name="name">mrp.mps.report.form</field>
        <field name="model">mrp.mps.report</field>
        <field name="arch" type="xml">
            <form string="Master Production Plan">
                <group>
                    <field name="date_from"/>
                    <field name="date_to"/>
                    <field name="only_draft"/>
                </group>
                <footer>
                    <button name="action_check" type="object" string="Check Feasibility"
                            class="oe_highlight"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_mrp_mps_report" model="ir.actions.act_window">
        <field name="name">Master Production Plan</field>
        <field name="res_model">mrp.mps.report</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_mrp_mps_report"
              name="Master Production Plan"
              parent="mrp.menu_mrp_root"
              action="action_mrp_mps_report"
              sequence="56"
              groups="mrp.group_mrp_user"/>

</odoo>
