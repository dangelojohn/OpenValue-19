<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_purchase_monitor_list" model="ir.ui.view">
        <field name="name">purchase.monitor.list</field>
        <field name="model">purchase.order.line</field>
        <field name="arch" type="xml">
            <list string="Purchase Monitor" create="false" decoration-danger="is_late == True">
                <field name="order_id"/>
                <field name="partner_id"/>
                <field name="product_id"/>
                <field name="product_qty"/>
                <field name="qty_received"/>
                <field name="qty_pending"/>
                <field name="date_planned"/>
                <field name="is_late"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_purchase_monitor_pivot" model="ir.ui.view">
        <field name="name">purchase.monitor.pivot</field>
        <field name="model">purchase.order.line</field>
        <field name="arch" type="xml">
            <pivot string="Purchase Monitor">
                <field name="partner_id" type="row"/>
                <field name="date_planned" interval="month" type="col"/>
                <field name="qty_pending" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_purchase_monitor_search" model="ir.ui.view">
        <field name="name">purchase.monitor.search</field>
        <field name="model">purchase.order.line</field>
        <field name="arch" type="xml">
            <search string="Purchase Monitor">
                <field name="order_id"/>
                <field name="partner_id"/>
                <field name="product_id"/>
                <filter name="to_receive" string="To Receive"
                        domain="[('qty_pending', '&gt;', 0)]"/>
                <separator/>
                <filter name="late" string="Late"
                        domain="[('qty_pending', '&gt;', 0), ('date_planned', '&lt;', context_today().strftime('%Y-%m-%d'))]"/>
            </search>
        </field>
    </record>

    <record id="action_purchase_monitor" model="ir.actions.act_window">
        <field name="name">Purchase Monitor</field>
        <field name="res_model">purchase.order.line</field>
        <field name="view_mode">list,pivot</field>
        <field name="domain">[('state', 'in', ('purchase', 'done'))]</field>
        <field name="context">{'search_default_to_receive': 1}</field>
        <field name="search_view_id" ref="view_purchase_monitor_search"/>
        <field name="view_id" ref="view_purchase_monitor_list"/>
    </record>

    <menuitem id="menu_purchase_monitor"
              name="Purchase Monitor"
              parent="purchase.menu_purchase_root"
              action="action_purchase_monitor"
              sequence="30"
              groups="purchase.group_purchase_user"/>

</odoo>
