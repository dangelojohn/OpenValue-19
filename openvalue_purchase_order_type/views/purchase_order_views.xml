<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_purchase_order_form_type" model="ir.ui.view">
        <field name="name">purchase.order.form.type</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <field name="partner_id" position="after">
                <field name="type_id"/>
            </field>
        </field>
    </record>

    <record id="view_purchase_order_filter_type" model="ir.ui.view">
        <field name="name">purchase.order.search.type</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.view_purchase_order_filter"/>
        <field name="arch" type="xml">
            <field name="partner_id" position="after">
                <field name="type_id"/>
            </field>
        </field>
    </record>

</odoo>
