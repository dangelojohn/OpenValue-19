<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_purchase_order_type_list" model="ir.ui.view">
        <field name="name">purchase.order.type.list</field>
        <field name="model">purchase.order.type</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_purchase_order_type_form" model="ir.ui.view">
        <field name="name">purchase.order.type.form</field>
        <field name="model">purchase.order.type</field>
        <field name="arch" type="xml">
            <form string="Purchase Order Type">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="sequence"/>
                        <field name="active" widget="boolean_toggle"/>
                        <field name="company_id" groups="base.group_multi_company"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_purchase_order_type" model="ir.actions.act_window">
        <field name="name">Order Types</field>
        <field name="res_model">purchase.order.type</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_purchase_order_type"
              name="Order Types"
              parent="purchase.menu_purchase_config"
              action="action_purchase_order_type"
              sequence="20"
              groups="purchase.group_purchase_manager"/>

</odoo>
