<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_mrp_planning_run_form_multilevel" model="ir.ui.view">
        <field name="name">mrp.planning.run.form.multilevel</field>
        <field name="model">mrp.planning.run</field>
        <field name="inherit_id" ref="openvalue_mrp_planning_engine.view_mrp_planning_run_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='warehouse_id']" position="after">
                <field name="multilevel" readonly="state == 'done'"/>
            </xpath>
        </field>
    </record>

</odoo>
